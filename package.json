{
  "name": "web-terminal",
  "version": "1.1.0",
  "description": "Web-based terminal emulator with split panes",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "cards": "node scripts/card-api-cli.js",
    "test": "npm run test:unit",
    "test:unit": "node --test test/*.test.js",
    "test:ui": "node scripts/test-ui-smoke.js",
    "test:all": "npm run test:unit && npm run test:ui"
  },
  "dependencies": {
    "@toast-ui/editor": "^3.2.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "express": "^4.21.0",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0"
  }
}
